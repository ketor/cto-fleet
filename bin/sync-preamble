#!/usr/bin/env bash
# sync-preamble — synchronize preamble and handoff section across all SKILL.md files
#
# Reads the canonical preamble from PREAMBLE.md and ensures all SKILL.md
# files in skill subdirectories have the exact same preamble block.
# Also checks/inserts the handoff section from HANDOFF.md into SKILL.md
# files that reference TeamCreate.
#
# Usage:
#   bin/sync-preamble              # check mode (default, report only)
#   bin/sync-preamble --fix        # fix mode (update mismatched preambles)
#   bin/sync-preamble --dry-run    # show what --fix would do, without writing
#   bin/sync-preamble --verbose    # show per-file check results
#   bin/sync-preamble --skills=team-dev,team-perf  # limit to specific skills
set -euo pipefail
trap 'rm -f "$CTO_FLEET_DIR"/*/.SKILL.md.tmp 2>/dev/null' EXIT

CTO_FLEET_DIR="${CTO_FLEET_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"
PREAMBLE_SOURCE="$CTO_FLEET_DIR/PREAMBLE.md"

# Parse arguments
FIX=0
DRY_RUN=0
VERBOSE=0
SKILL_FILTER=""

for arg in "$@"; do
  case "$arg" in
    --fix)     FIX=1 ;;
    --dry-run) DRY_RUN=1; FIX=1 ;;
    --verbose) VERBOSE=1 ;;
    --skills=*) SKILL_FILTER="${arg#--skills=}" ;;
    --help|-h)
      echo "Usage: sync-preamble [--fix] [--dry-run] [--verbose] [--skills=s1,s2]"
      echo ""
      echo "Options:"
      echo "  --fix        Update mismatched preambles (default: check only)"
      echo "  --dry-run    Show what --fix would change without writing"
      echo "  --verbose    Show per-file check results"
      echo "  --skills=X   Comma-separated list of skills to process"
      exit 0
      ;;
    *) echo "Unknown option: $arg" >&2; exit 1 ;;
  esac
done

# ─── Extract canonical preamble from a reference SKILL.md ─────
# PREAMBLE.md contains escaped backticks, so we extract from an actual SKILL.md
# Find the first SKILL.md with a preamble as canonical source
CANONICAL=""
for ref_dir in "$CTO_FLEET_DIR"/team-dev "$CTO_FLEET_DIR"/team-review "$CTO_FLEET_DIR"/team-*/; do
  ref_file="$ref_dir/SKILL.md"
  [ -f "$ref_file" ] || continue
  # Extract preamble: from "## Preamble (run first)" to the next "---"
  in_p=0
  while IFS= read -r line; do
    if [ $in_p -eq 0 ] && echo "$line" | grep -q '^## Preamble (run first)'; then
      in_p=1
      CANONICAL="$line"
      continue
    fi
    if [ $in_p -eq 1 ]; then
      [ "$line" = "---" ] && break
      CANONICAL="$CANONICAL
$line"
    fi
  done < "$ref_file"
  [ -n "$CANONICAL" ] && break
done

if [ -z "$CANONICAL" ]; then
  echo "Error: could not find a reference preamble in any SKILL.md" >&2
  exit 1
fi

# ─── Build skill list ─────────────────────────────────────────
skills=()
if [ -n "$SKILL_FILTER" ]; then
  IFS=',' read -ra filter_list <<< "$SKILL_FILTER"
  for s in "${filter_list[@]}"; do
    skill_file="$CTO_FLEET_DIR/$s/SKILL.md"
    if [ -f "$skill_file" ]; then
      skills+=("$skill_file")
    else
      echo "Warning: $skill_file not found, skipping" >&2
    fi
  done
else
  for skill_dir in "$CTO_FLEET_DIR"/*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    skills+=("$skill_dir/SKILL.md")
  done
fi

if [ ${#skills[@]} -eq 0 ]; then
  echo "No SKILL.md files found" >&2
  exit 1
fi

# ─── Check/fix each skill ────────────────────────────────────
count_ok=0
count_fix=0
count_missing=0
count_error=0

for skill_file in "${skills[@]}"; do
  skill_name="$(basename "$(dirname "$skill_file")")"

  # Extract existing preamble from SKILL.md
  # Preamble starts at "## Preamble (run first)" and ends at the next "---" separator
  existing=""
  in_preamble=0
  preamble_start_line=0
  preamble_end_line=0
  line_num=0
  found_frontmatter_end=0

  while IFS= read -r line; do
    line_num=$((line_num + 1))

    # Skip YAML frontmatter (first --- to second ---)
    if [ "$line" = "---" ] && [ $found_frontmatter_end -lt 2 ]; then
      found_frontmatter_end=$((found_frontmatter_end + 1))
      continue
    fi

    if [ $in_preamble -eq 0 ] && echo "$line" | grep -q '^## Preamble (run first)'; then
      in_preamble=1
      preamble_start_line=$line_num
      existing="$line"
      continue
    fi

    if [ $in_preamble -eq 1 ]; then
      if [ "$line" = "---" ]; then
        preamble_end_line=$line_num
        break
      fi
      existing="$existing
$line"
    fi
  done < "$skill_file"

  # Remove trailing empty lines for comparison
  existing_trimmed="$(echo "$existing" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')"
  canonical_trimmed="$(echo "$CANONICAL" | sed -e :a -e '/^[[:space:]]*$/{ $d; N; ba; }')"

  if [ $preamble_start_line -eq 0 ]; then
    # No preamble found
    count_missing=$((count_missing + 1))
    echo "✗ $skill_name/SKILL.md: preamble MISSING"
    if [ $FIX -eq 1 ]; then
      if [ $DRY_RUN -eq 1 ]; then
        echo "  → dry-run: would insert preamble after frontmatter"
      else
        # Insert preamble after the second --- (frontmatter end)
        # Find the line number of the second ---
        fm_end=0
        fm_count=0
        while IFS= read -r line; do
          fm_end=$((fm_end + 1))
          if [ "$line" = "---" ]; then
            fm_count=$((fm_count + 1))
            [ $fm_count -ge 2 ] && break
          fi
        done < "$skill_file"

        if [ $fm_count -ge 2 ]; then
          # Split file and insert preamble
          head -n "$fm_end" "$skill_file" > "$skill_file.tmp"
          echo "" >> "$skill_file.tmp"
          echo "$CANONICAL" >> "$skill_file.tmp"
          echo "" >> "$skill_file.tmp"
          echo "---" >> "$skill_file.tmp"
          tail -n +"$((fm_end + 1))" "$skill_file" >> "$skill_file.tmp"
          mv "$skill_file.tmp" "$skill_file"
          echo "  → inserted preamble"
        else
          echo "  → error: could not find frontmatter end" >&2
          count_error=$((count_error + 1))
        fi
      fi
    fi
  elif [ "$existing_trimmed" = "$canonical_trimmed" ]; then
    count_ok=$((count_ok + 1))
    [ $VERBOSE -eq 1 ] && echo "✓ $skill_name/SKILL.md: OK"
  else
    count_fix=$((count_fix + 1))
    echo "✗ $skill_name/SKILL.md: preamble OUTDATED"
    if [ $FIX -eq 1 ]; then
      if [ $DRY_RUN -eq 1 ]; then
        echo "  → dry-run: would update preamble (lines $preamble_start_line-$((preamble_end_line - 1)))"
      else
        # Replace preamble region
        head -n "$((preamble_start_line - 1))" "$skill_file" > "$skill_file.tmp"
        echo "$CANONICAL" >> "$skill_file.tmp"
        echo "" >> "$skill_file.tmp"
        tail -n +"$preamble_end_line" "$skill_file" >> "$skill_file.tmp"
        mv "$skill_file.tmp" "$skill_file"
        echo "  → updated preamble"
      fi
    fi
  fi
done

# ─── Handoff section sync ─────────────────────────────────────
HANDOFF_SOURCE="$CTO_FLEET_DIR/HANDOFF.md"
HANDOFF_START="<!-- HANDOFF_SECTION_START -->"
HANDOFF_END="<!-- HANDOFF_SECTION_END -->"

handoff_ok=0
handoff_missing=0
handoff_outdated=0
handoff_skipped=0
handoff_error=0

# Extract canonical handoff section from HANDOFF.md
HANDOFF_SECTION=""
if [ -f "$HANDOFF_SOURCE" ]; then
  in_hs=0
  while IFS= read -r line; do
    if [ "$line" = "$HANDOFF_START" ]; then
      in_hs=1
      HANDOFF_SECTION="$line"
      continue
    fi
    if [ $in_hs -eq 1 ]; then
      HANDOFF_SECTION="$HANDOFF_SECTION
$line"
      [ "$line" = "$HANDOFF_END" ] && break
    fi
  done < "$HANDOFF_SOURCE"
fi

if [ -z "$HANDOFF_SECTION" ]; then
  echo ""
  echo "Handoff: skipped (HANDOFF.md not found or missing HANDOFF_SECTION markers)"
else
  echo ""
  echo "Handoff section check:"

  for skill_file in "${skills[@]}"; do
    skill_name="$(basename "$(dirname "$skill_file")")"

    # Check if this SKILL.md references TeamCreate
    if ! grep -q 'TeamCreate' "$skill_file" 2>/dev/null; then
      handoff_skipped=$((handoff_skipped + 1))
      [ $VERBOSE -eq 1 ] && echo "  - $skill_name/SKILL.md: no TeamCreate, skipped"
      continue
    fi

    # Check if handoff section exists
    has_start=0
    has_end=0
    grep -q "$HANDOFF_START" "$skill_file" 2>/dev/null && has_start=1
    grep -q "$HANDOFF_END" "$skill_file" 2>/dev/null && has_end=1

    if [ $has_start -eq 1 ] && [ $has_end -eq 1 ]; then
      # Extract existing handoff section for comparison
      existing_hs=""
      in_ehs=0
      while IFS= read -r line; do
        if [ "$line" = "$HANDOFF_START" ]; then
          in_ehs=1
          existing_hs="$line"
          continue
        fi
        if [ $in_ehs -eq 1 ]; then
          existing_hs="$existing_hs
$line"
          [ "$line" = "$HANDOFF_END" ] && break
        fi
      done < "$skill_file"

      if [ "$existing_hs" = "$HANDOFF_SECTION" ]; then
        handoff_ok=$((handoff_ok + 1))
        [ $VERBOSE -eq 1 ] && echo "  ✓ $skill_name/SKILL.md: handoff OK"
      else
        handoff_outdated=$((handoff_outdated + 1))
        echo "  ✗ $skill_name/SKILL.md: handoff OUTDATED"
        if [ $FIX -eq 1 ]; then
          if [ $DRY_RUN -eq 1 ]; then
            echo "    → dry-run: would update handoff section"
          else
            # Replace existing handoff section
            hs_start_line=0
            hs_end_line=0
            hs_line_num=0
            while IFS= read -r line; do
              hs_line_num=$((hs_line_num + 1))
              [ "$line" = "$HANDOFF_START" ] && hs_start_line=$hs_line_num
              if [ "$line" = "$HANDOFF_END" ]; then
                hs_end_line=$hs_line_num
                break
              fi
            done < "$skill_file"

            if [ $hs_start_line -gt 0 ] && [ $hs_end_line -gt 0 ]; then
              head -n "$((hs_start_line - 1))" "$skill_file" > "$skill_file.tmp"
              echo "$HANDOFF_SECTION" >> "$skill_file.tmp"
              tail -n +"$((hs_end_line + 1))" "$skill_file" >> "$skill_file.tmp"
              mv "$skill_file.tmp" "$skill_file"
              echo "    → updated handoff section"
            else
              echo "    → error: could not locate handoff markers" >&2
              handoff_error=$((handoff_error + 1))
            fi
          fi
        fi
      fi
    else
      # Handoff section missing — need to insert
      handoff_missing=$((handoff_missing + 1))
      echo "  ✗ $skill_name/SKILL.md: handoff MISSING"
      if [ $FIX -eq 1 ]; then
        if [ $DRY_RUN -eq 1 ]; then
          echo "    → dry-run: would insert handoff section after TeamCreate line"
        else
          # Find the line number of the first line containing TeamCreate
          tc_line=0
          tc_line_num=0
          while IFS= read -r line; do
            tc_line_num=$((tc_line_num + 1))
            if echo "$line" | grep -q 'TeamCreate'; then
              tc_line=$tc_line_num
              break
            fi
          done < "$skill_file"

          if [ $tc_line -gt 0 ]; then
            head -n "$tc_line" "$skill_file" > "$skill_file.tmp"
            echo "" >> "$skill_file.tmp"
            echo "$HANDOFF_SECTION" >> "$skill_file.tmp"
            echo "" >> "$skill_file.tmp"
            tail -n +"$((tc_line + 1))" "$skill_file" >> "$skill_file.tmp"
            mv "$skill_file.tmp" "$skill_file"
            echo "    → inserted handoff section after TeamCreate"
          else
            echo "    → error: could not find TeamCreate line" >&2
            handoff_error=$((handoff_error + 1))
          fi
        fi
      fi
    fi
  done

  handoff_total=$((handoff_ok + handoff_missing + handoff_outdated))
  echo ""
  echo "Handoff: $handoff_ok OK, $handoff_outdated outdated, $handoff_missing missing, $handoff_error errors (total: $handoff_total team skills, $handoff_skipped skipped)"
fi

# ─── Summary ──────────────────────────────────────────────────
echo ""
total=${#skills[@]}
echo "Preamble: $count_ok OK, $count_fix outdated, $count_missing missing, $count_error errors (total: $total)"
if [ $FIX -eq 0 ] && [ $((count_fix + count_missing + handoff_missing + handoff_outdated)) -gt 0 ]; then
  echo "Run with --fix to update, or --dry-run to preview changes."
fi

[ $((count_fix + count_missing + count_error + handoff_missing + handoff_outdated + handoff_error)) -eq 0 ] && exit 0 || exit 1
